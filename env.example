# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: API version prefix (e.g. v1). Defaults to v1. Must be set in production to avoid .../undefined/... in URLs.
# NEXT_PUBLIC_API_VERSION=v1

# App Configuration
NEXT_PUBLIC_APP_NAME=FinanceApp
NEXT_PUBLIC_APP_VERSION=1.0.0

# Development Server Port (configured in package.json)
# Frontend runs on: http://localhost:3005
# Backend should run on: http://localhost:3001
